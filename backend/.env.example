# Interview Tester Configuration
# Copy this file to .env and modify as needed
# All variables are prefixed with INTERVIEW_

# ---- LLM Provider ----
# Options: "ollama" (local) or "openrouter" (cloud)
INTERVIEW_LLM_PROVIDER=ollama

# Ollama settings (when LLM_PROVIDER=ollama)
INTERVIEW_OLLAMA_BASE_URL=http://localhost:11434
INTERVIEW_OLLAMA_MODEL=mistral:7b-instruct-q4_0

# OpenRouter settings (when LLM_PROVIDER=openrouter)
# Get your free API key at: https://openrouter.ai/keys
INTERVIEW_OPENROUTER_API_KEY=
INTERVIEW_OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# ---- Whisper speech-to-text ----
INTERVIEW_WHISPER_MODEL=base          # Options: tiny, base, small, medium
INTERVIEW_WHISPER_LANGUAGE=en         # Options: en, zh (Mandarin), yue (Cantonese)

# ---- General ----
INTERVIEW_MAX_QUESTIONS_PER_SESSION=5
INTERVIEW_DATABASE_PATH=interview_tester.db
INTERVIEW_CORS_ORIGINS=["http://localhost:5173"]
